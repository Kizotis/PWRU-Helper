<Window x:Class="PWRUHelper.CompactOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PWRU Helper (compact)"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        Width="360" Height="440" MinWidth="240" MinHeight="180">

    <Border Background="#F2071C2F" CornerRadius="10"
            BorderBrush="{StaticResource GoldBrush}" BorderThickness="1">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== Header (drag to move) ===== -->
            <Grid Grid.Row="0" x:Name="HeaderBar" Background="Transparent"
                  MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PWRU" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text=" Helper" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="LiveDot" Text="  ●  LIVE" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="LiveToggleButton" Style="{StaticResource GhostButton}" Padding="8,2"
                            Content="▶ Live" Click="LiveToggle_Click"
                            ToolTip="Start / stop live translation on your last area (Ctrl+Alt+L)"
                            AutomationProperties.Name="Start or stop live translation"/>
                    <Button Style="{StaticResource GhostButton}" Padding="8,2" Margin="6,0,0,0"
                            Content="⤢" Click="Expand_Click" ToolTip="Back to the full window"
                            AutomationProperties.Name="Back to the full window"/>
                </StackPanel>
            </Grid>

            <!-- ===== Live status line ===== -->
            <TextBlock x:Name="OverlayStatus" Grid.Row="1" TextWrapping="Wrap" FontSize="11"
                       Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" Visibility="Collapsed"/>

            <!-- ===== Live feed (shared with the main window) ===== -->
            <ScrollViewer x:Name="FeedScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Margin="0,8,0,0" Padding="0,0,6,0">
                <StackPanel>
                    <TextBlock x:Name="EmptyHint" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               Text="Press ▶ Live to translate your chat here. Type below to send a Russian reply."/>
                    <ItemsControl x:Name="FeedItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelBrush}" CornerRadius="6"
                                        Padding="8,6" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Original}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Translation}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Glossary}" FontSize="11"
                                                   Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Quick reply ===== -->
            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <TextBox x:Name="ReplyBox" KeyDown="ReplyBox_KeyDown" TextChanged="ReplyBox_TextChanged"
                             VerticalContentAlignment="Center" Padding="6,4"/>
                    <TextBlock x:Name="ReplyPlaceholder" IsHitTestVisible="False"
                               Text="Type a reply → Enter (→ Russian, copied)"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
                <TextBlock x:Name="ReplyResult" Grid.Row="1" TextWrapping="Wrap" Margin="2,4,0,0"
                           FontSize="12" Foreground="{StaticResource GoldBrush}"/>

                <!-- Long reply: split into game-sized blocks to copy & send one after another. -->
                <StackPanel x:Name="ReplyBlocksPanel" Grid.Row="2" Visibility="Collapsed" Margin="0,4,0,0">
                    <TextBlock x:Name="ReplyBlocksHint" TextWrapping="Wrap" FontSize="11" Margin="2,0,0,4"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Too long for one chat message — copy each block and send them in order:"/>
                    <ItemsControl x:Name="ReplyBlocks">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="Bold"
                                               Foreground="{StaticResource GoldBrush}" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                                            Padding="8,5">
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}" Padding="8,2"
                                            Margin="6,0,0,0" Content="Copy" Click="CopyBlock_Click"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
