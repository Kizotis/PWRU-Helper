<Window x:Class="PWRUHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PWRUHelper"
        Title="PWRU Helper" Height="720" Width="640"
        MinHeight="480" MinWidth="460"
        Icon="assets/icon.png"
        Background="{StaticResource BackgroundBrush}"
        Topmost="True">

    <Window.Resources>
        <!-- Available width → phrase-grid column count (keeps cards a comfortable size) -->
        <local:WidthToColumnsConverter x:Key="WidthToColumns" ItemMinWidth="210" MaxColumns="6"/>

        <!-- ★ pin/unpin toggle used on each phrase card -->
        <Style x:Key="PinButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="☆"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="ToolTip" Value="Pin to Favourites"/>
            <Setter Property="AutomationProperties.Name" Value="Pin to Favourites"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="4,0">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavourite}" Value="True">
                    <Setter Property="Content" Value="★"/>
                    <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                    <Setter Property="ToolTip" Value="Unpin from Favourites"/>
                    <Setter Property="AutomationProperties.Name" Value="Unpin from Favourites"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Phrase card button -->
        <Style x:Key="PhraseCard" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="4,0,4,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{StaticResource PanelBrush}" CornerRadius="8"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Ru}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding En}" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Translit}" FontSize="10" FontStyle="Italic"
                                               Foreground="{StaticResource TealBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource PinButton}"
                                        VerticalAlignment="Top" Click="TogglePin_Click"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="PWRU" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text=" Helper" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <CheckBox x:Name="TopmostCheck" Content="Always on top" IsChecked="True"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextMutedBrush}"
                          Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"/>
                <Button Style="{StaticResource GhostButton}" Padding="7,3" Margin="10,0,0,0"
                        Content="A−" Click="FontSmaller_Click" ToolTip="Smaller text"
                        AutomationProperties.Name="Smaller text"/>
                <Button Style="{StaticResource GhostButton}" Padding="7,3" Margin="4,0,0,0"
                        Content="A+" Click="FontLarger_Click" ToolTip="Larger text"
                        AutomationProperties.Name="Larger text"/>
                <Button x:Name="CompactButton" Style="{StaticResource GhostButton}" Padding="8,3"
                        Margin="10,0,0,0" Content="⤡ Compact" Click="CompactButton_Click"
                        ToolTip="Shrink to a small overlay for playing (Ctrl+Alt+M)"
                        AutomationProperties.Name="Switch to compact overlay"/>
            </StackPanel>
        </Grid>

        <!-- ===== Tabs ===== -->
        <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent"
                    SelectionChanged="MainTabs_SelectionChanged">

            <!-- ===================== TAB 1: PHRASEBOOK ===================== -->
            <TabItem Header="Phrasebook">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBox x:Name="PhraseSearch" TextChanged="PhraseSearch_TextChanged"/>
                        <!-- placeholder label so it's clearly the search bar -->
                        <TextBlock x:Name="SearchPlaceholder" IsHitTestVisible="False"
                                   Text="🔍  Searchbar — type to filter phrases (English, Russian, sound)…"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </Grid>
                    <ScrollViewer x:Name="PhraseScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,6,0">
                        <ItemsControl x:Name="PhraseList">
                            <!-- columns adapt to the window width (see WidthToColumnsConverter),
                                 so cards stay a comfortable size instead of a fixed 4-up -->
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding ActualWidth,
                                                     RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                     Converter={StaticResource WidthToColumns}}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource GoldBrush}"
                                                       Padding="2,0,0,0" Margin="0,12,0,6"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                    <!-- groups stack vertically down the page -->
                                    <GroupStyle.Panel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </GroupStyle.Panel>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PhraseCard}" Click="PhraseCard_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===================== TAB 2: SQUAD BUILDER ===================== -->
            <TabItem Header="Squad">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="2,0,6,0">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Margin="2,0,0,2" Foreground="{StaticResource TextMutedBrush}"
                                       Text="Make a group-forming message: tick the dungeon(s) and class(es) you're looking for, then copy the Russian phrase and paste it in chat."/>

                            <TextBlock Text="Dungeons" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}" Margin="0,14,0,6"/>
                            <!-- three titled columns built in code from Data/squad.json -->
                            <Grid x:Name="SquadDungeonGrid"/>

                            <TextBlock Text="Classes" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}" Margin="0,18,0,6"/>
                            <Grid x:Name="SquadClassGrid"/>

                            <TextBlock x:Name="SquadEmptyHint" Visibility="Collapsed" TextWrapping="Wrap"
                                       Margin="0,10,0,0" Foreground="{StaticResource GoldBrush}"
                                       Text="Couldn't load squad.json — reinstall or restore it next to the app (or in %AppData%\PWRUHelper)."/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="12" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Your message (paste in chat with Ctrl+V)"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,6"/>
                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="SquadPhraseBox" IsReadOnly="True"
                                     VerticalAlignment="Center" FontSize="15" Padding="10,8"
                                     Foreground="{StaticResource GoldBrush}"/>
                            <Button Grid.Row="1" Grid.Column="1" Content="📋  Copy" Style="{StaticResource AccentButton}"
                                    Margin="8,0,0,0" Padding="16,8" Click="SquadCopy_Click"
                                    AutomationProperties.Name="Copy the squad message"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Padding="14,8" Click="SquadClear_Click"
                                    AutomationProperties.Name="Uncheck everything"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===================== TAB 3: TRANSLATOR (write + read from screen) ===================== -->
            <TabItem Header="Translator">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,6" FontSize="13">
                        <Run Text="✍  Write — type and get the translation"
                             FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/><Run
                             Text="    ·  press Ctrl+Enter to translate" Foreground="{StaticResource TextMutedBrush}"/>
                    </TextBlock>

                    <!-- direction controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <!-- items filled in code from a single language list (see PopulateLanguageCombos) -->
                        <ComboBox x:Name="FromCombo" Width="120" VerticalAlignment="Center"/>
                        <Button Content="&#8646;" Style="{StaticResource GhostButton}" Margin="8,0"
                                Click="Swap_Click" ToolTip="Swap languages"
                                AutomationProperties.Name="Swap languages"/>
                        <ComboBox x:Name="ToCombo" Width="120" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBox x:Name="TranslateInput" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" MinHeight="60"
                             KeyDown="TranslateInput_KeyDown"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8">
                        <Button x:Name="TranslateButton" Style="{StaticResource AccentButton}"
                                Content="Translate" Click="Translate_Click"/>
                        <Button x:Name="CopyResultButton" Style="{StaticResource GhostButton}"
                                Content="Copy result" Margin="8,0,0,0" Click="CopyResult_Click"/>
                        <CheckBox x:Name="AutoCopyCheck" Content="Auto-copy" IsChecked="True"
                                  VerticalAlignment="Center" Margin="12,0,0,0"
                                  Foreground="{StaticResource TextMutedBrush}"
                                  ToolTip="Copy the translation automatically so you can paste it in game with Ctrl+V."/>
                        <TextBlock x:Name="TranslateStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                    <TextBox x:Name="TranslateOutput" Grid.Row="4" IsReadOnly="True" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="60"
                             FontSize="16" Foreground="{StaticResource GoldBrush}"/>

                    <!-- reading from screen -->
                    <Grid Grid.Row="5" Margin="0,14,0,6">
                        <TextBlock Text="👁  From screen — reading &amp; live translation"
                                   FontWeight="Bold" FontSize="13" Foreground="{StaticResource GoldBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="LiveIndicator" Text="● LIVE" Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <Button x:Name="StopLiveButton" Content="■ Stop" Style="{StaticResource GhostButton}"
                                    Padding="10,3" Margin="10,0,0,0" Visibility="Collapsed" Click="StopLive_Click"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="ResultsScroller" Grid.Row="6" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                        <StackPanel>
                            <TextBlock x:Name="ScreenReadStatus" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Pick a screen area in the Screen OCR tab (read once, or live). The Russian text and its translation will appear here."/>
                            <ItemsControl x:Name="OcrResults">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelBrush}" CornerRadius="8"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="13" TextWrapping="Wrap"><Run Text="{Binding SpeakerPrefix, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/><Run Text="{Binding OriginalBody, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}"/></TextBlock>
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"><Run Text="{Binding SpeakerPrefix, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}"/><Run Text="{Binding TranslationBody, Mode=OneWay}" Foreground="{StaticResource TextBrush}"/></TextBlock>
                                                    <TextBlock Text="{Binding Glossary}" FontSize="12"
                                                               Foreground="{StaticResource GoldBrush}"
                                                               TextWrapping="Wrap" Margin="0,3,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="Text" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="⧉" Style="{StaticResource GhostButton}"
                                                        Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top"
                                                        Click="CopyOriginal_Click" ToolTip="Copy the Russian text"
                                                        AutomationProperties.Name="Copy the Russian text"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===================== TAB 3: SCREEN OCR (controls + settings) ===================== -->
            <TabItem Header="Screen OCR">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2,0,6,0">
                    <StackPanel Margin="0,10,0,0">

                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"
                                   Text="Capture Russian text from your screen and translate it. The results appear in the Translator tab."/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="SelectAreaButton" Style="{StaticResource AccentButton}"
                                    Content="Select area &amp; read once" Click="SelectArea_Click"
                                    ToolTip="Draw a box over Russian text and read it once. Ctrl+Alt+R re-reads the same area while in game."/>
                            <TextBlock Text="translate to" VerticalAlignment="Center" Margin="12,0,6,0"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <ComboBox x:Name="OcrTargetCombo" VerticalAlignment="Center" Width="120"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LiveButton" Style="{StaticResource AccentButton}"
                                    Content="▶  Start live translation" Click="LiveButton_Click"/>
                            <Button x:Name="ResumeLiveButton" Style="{StaticResource GhostButton}"
                                    Content="↻  Resume last area" Margin="8,0,0,0" Visibility="Collapsed"
                                    Click="ResumeLive_Click"
                                    ToolTip="Start live on the area you used last time (no need to re-select)."/>
                        </StackPanel>
                        <TextBlock x:Name="LiveStatus" TextWrapping="Wrap" Margin="0,6,0,10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Live mode keeps watching the chosen area and re-translates automatically whenever new text appears, until you press Stop."/>

                        <!-- Live OCR sensitivity -->
                        <StackPanel Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="OCR sensitivity" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SensitivityValue" Text="5%" Margin="8,0,0,0"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider x:Name="SensitivitySlider" Minimum="0" Maximum="100" Value="5"
                                    TickFrequency="10" Width="280" HorizontalAlignment="Left"
                                    Margin="0,4,0,2" ValueChanged="SensitivitySlider_ValueChanged"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Text="Lower = calmer: ignores tiny changes and background movement (e.g. panning the camera behind the chat). Higher = catches every little change, but may re-translate more often."/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Live speed" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LiveSpeedValue" Text="~1.0s between reads" Margin="8,0,0,0"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider x:Name="LiveSpeedSlider" Minimum="0" Maximum="100" Value="80"
                                    TickFrequency="10" Width="280" HorizontalAlignment="Left"
                                    Margin="0,4,0,2" ValueChanged="LiveSpeedSlider_ValueChanged"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Text="How often live mode re-reads the screen. Slide left to slow it down if it translates too fast; right to react quicker."/>

                            <!-- Smallest text fragment -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Smallest text fragment" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="MinFragmentValue" Text="2 letters" Margin="8,0,0,0"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider x:Name="MinFragmentSlider" Minimum="1" Maximum="6" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Width="280" HorizontalAlignment="Left"
                                    Margin="0,4,0,2" ValueChanged="MinFragmentSlider_ValueChanged"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Text="Ignore fragments shorter than this many letters. Raise it to skip stray specks and single-letter OCR noise."/>

                            <!-- Stability (frame confirmation) -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Stability" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StabilityValue" Text="60%" Margin="8,0,0,0"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider x:Name="StabilitySlider" Minimum="0" Maximum="100" Value="60"
                                    TickFrequency="10" Width="280" HorizontalAlignment="Left"
                                    Margin="0,4,0,2" ValueChanged="StabilitySlider_ValueChanged"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Text="How strictly a new line must stay put for one read before it's translated. Higher = fewer false lines from flicker, but a touch slower to confirm real text."/>
                        </StackPanel>

                        <!-- Background filter (optional pre-OCR clean-up) -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Background filter" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,4"
                                       Text="Clean up the moving 3D scene behind the chat before reading. 'Boost contrast' keeps bright text of any colour; 'Keep one colour' isolates a single chat channel by its colour (paste a hex like #FFDC50 and widen the tolerance until only that channel shows)."/>
                            <ComboBox x:Name="OcrFilterCombo" Width="260" HorizontalAlignment="Left"
                                      SelectionChanged="OcrFilterCombo_Changed">
                                <ComboBoxItem Content="Off" Tag="off"/>
                                <ComboBoxItem Content="Boost contrast (any colour)" Tag="contrast"/>
                                <ComboBoxItem Content="Keep one colour" Tag="color"/>
                            </ComboBox>
                            <StackPanel x:Name="OcrColorOptions" Orientation="Horizontal" Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Text="Colour" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox x:Name="OcrColorHexBox" Width="90" Margin="6,0,0,0"
                                         VerticalContentAlignment="Center" Text="#FFFFFF"
                                         TextChanged="OcrColorHex_Changed"
                                         LostFocus="OcrColorHex_LostFocus"/>
                                <TextBlock Text="tolerance" VerticalAlignment="Center" Margin="14,0,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <Slider x:Name="OcrToleranceSlider" Minimum="0" Maximum="441" Value="70" Width="130"
                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                        ValueChanged="OcrTolerance_Changed"/>
                                <TextBlock x:Name="OcrToleranceValue" Text="70" VerticalAlignment="Center"
                                           Margin="6,0,0,0" Foreground="{StaticResource GoldBrush}" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Capture method -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Capture method" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,4"
                                       Text="How the screen is grabbed. Default (GDI) works for windowed / borderless games. Try 'Windows Graphics (experimental)' only if capture comes out black in full-screen — it automatically falls back to GDI if it can't run."/>
                            <ComboBox x:Name="CaptureBackendCombo" Width="300" HorizontalAlignment="Left"
                                      SelectionChanged="CaptureBackend_Changed">
                                <ComboBoxItem Content="Default (GDI)" Tag="gdi"/>
                                <ComboBoxItem Content="Windows Graphics — experimental" Tag="wgc"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Screen OCR settings: Russian OCR language pack -->
                        <Border x:Name="OcrSettingsPanel" Margin="0,0,0,10"
                                Background="{StaticResource PanelBrush}" CornerRadius="8"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                            <StackPanel>
                                <TextBlock Text="⚙  Screen OCR — settings" FontWeight="Bold" FontSize="13"
                                           Foreground="{StaticResource GoldBrush}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="💡 Tip: for the most accurate reading, select only the last 3–4 lines of the chat rather than the whole chat window. A smaller, tighter area is read far more precisely."/>
                                <TextBlock x:Name="OcrLangStatus" TextWrapping="Wrap" Margin="0,6,0,0"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="Russian OCR language pack: checking…"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="InstallOcrButton" Style="{StaticResource AccentButton}"
                                            Content="Install Russian OCR (1 click)" Click="InstallOcr_Click"/>
                                    <TextBlock Text="asks for admin permission" VerticalAlignment="Center"
                                               Margin="10,0,0,0" Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,12,0,4"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="12">
                                    <Run Text="…or do it yourself: right-click Start → "/><Run Text="Terminal (Admin)" FontWeight="Bold"/><Run Text=" or "/><Run Text="Windows PowerShell (Admin)" FontWeight="Bold"/><Run Text=", then paste the line below. "/><LineBreak/><Run Text="⚠ Must be PowerShell — this will NOT work in Command Prompt (cmd)." FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                                </TextBlock>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Text is set in code from the OcrCapability constant (single source) -->
                                    <TextBox x:Name="OcrCommandBox" Grid.Column="0" IsReadOnly="True"
                                             FontFamily="Consolas" FontSize="12" VerticalContentAlignment="Center"/>
                                    <Button x:Name="CopyCmdButton" Grid.Column="1" Style="{StaticResource GhostButton}"
                                            Content="Copy" Margin="8,0,0,0" Click="CopyOcrCommand_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== TAB 5: ABOUT ===================== -->
            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2,0,6,0">
                    <StackPanel Margin="4,14,4,4">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PWRU" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text=" Helper" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock x:Name="VersionText" Text="  " FontSize="13" VerticalAlignment="Bottom" Margin="4,0,0,3"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <TextBlock Text="A free helper for the Perfect World RU (pwonline.ru) community."
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                        <!-- updates -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="⭳ Check for updates" Style="{StaticResource GhostButton}" Padding="10,4"
                                    Click="CheckForUpdates_Click"/>
                            <TextBlock x:Name="UpdateStatus" VerticalAlignment="Center" Margin="10,0,0,0"
                                       TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <!-- free-project message -->
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="8"
                                BorderBrush="{StaticResource GoldBrush}" BorderThickness="1"
                                Padding="14" Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" LineHeight="20">
                                This is a free project I made to help people. If you'd like me to add or
                                change something, feel free to send me a message! Just remember it's free
                                and made on my own time — so please don't expect changes the same day. 🙂
                            </TextBlock>
                        </Border>

                        <!-- keyboard shortcuts -->
                        <TextBlock Text="Global shortcuts (work while in game)" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,18,0,6"/>
                        <TextBlock Margin="0,2" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Ctrl+Alt+P" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <Run Text="  bring PWRU Helper to the front"/>
                        </TextBlock>
                        <TextBlock Margin="0,2" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Ctrl+Alt+T" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <Run Text="  jump to the translator and start typing"/>
                        </TextBlock>
                        <TextBlock Margin="0,2" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Ctrl+Alt+L" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <Run Text="  start / stop live translation on your last area"/>
                        </TextBlock>
                        <TextBlock Margin="0,2" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Ctrl+Alt+M" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <Run Text="  toggle the compact overlay (small in-game window)"/>
                        </TextBlock>
                        <TextBlock Margin="0,2" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Ctrl+Alt+R" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <Run Text="  read your last area once (no live loop)"/>
                        </TextBlock>
                        <!-- Made visible in code (OnSourceInitialized) listing any combo another app already owns -->
                        <TextBlock x:Name="HotkeyWarning" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="Collapsed" Foreground="{StaticResource GoldBrush}"/>

                        <!-- optional DeepL key -->
                        <TextBlock Text="Better translations (optional)" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,18,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6">
                            <Run Text="By default translation uses Google (free, no setup). If you have a free "/><Hyperlink
                                    NavigateUri="https://www.deepl.com/pro-api" RequestNavigate="OpenLink"
                                    Foreground="{StaticResource TealBrush}">DeepL API key</Hyperlink><Run
                                    Text=" you can paste it here for higher-quality translations — the app falls back to Google if DeepL is unavailable. The key is stored only on your PC."/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <PasswordBox x:Name="DeepLKeyBox" Width="300" VerticalContentAlignment="Center"/>
                            <Button Content="Save" Style="{StaticResource GhostButton}" Padding="12,4"
                                    Margin="8,0,0,0" Click="DeepLSaveKey_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="DeepLStatus" Margin="0,6,0,0" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>

                        <!-- troubleshooting -->
                        <TextBlock Text="Something went wrong?" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,18,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6">
                            Copy the recent error log and send it to me on Discord so I can see what happened.
                        </TextBlock>
                        <Button Content="📋 Copy error report" Style="{StaticResource GhostButton}" Padding="10,4"
                                HorizontalAlignment="Left" Click="CopyErrorReport_Click"/>

                        <!-- author links -->
                        <TextBlock Text="Made by Kizotis" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,18,0,8"/>

                        <TextBlock Margin="0,3">
                            <Run Text="🌐  GitHub:  " Foreground="{StaticResource TextMutedBrush}"/>
                            <Hyperlink NavigateUri="https://github.com/Kizotis" RequestNavigate="OpenLink"
                                       Foreground="{StaticResource TealBrush}">github.com/Kizotis</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="🟣  Twitch:  " Foreground="{StaticResource TextMutedBrush}"/>
                            <Hyperlink NavigateUri="https://www.twitch.tv/kizotis" RequestNavigate="OpenLink"
                                       Foreground="{StaticResource TealBrush}">twitch.tv/kizotis</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="▶  YouTube:  " Foreground="{StaticResource TextMutedBrush}"/>
                            <Hyperlink NavigateUri="https://www.youtube.com/@kizotis" RequestNavigate="OpenLink"
                                       Foreground="{StaticResource TealBrush}">youtube.com/@kizotis</Hyperlink>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock>
                                <Run Text="💬  Discord:  " Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="kizotis" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <Button Content="Copy" Style="{StaticResource GhostButton}" Padding="8,2"
                                    Margin="10,0,0,0" Click="CopyDiscord_Click"/>
                        </StackPanel>

                        <!-- community -->
                        <TextBlock Text="PWRU English community" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,18,0,8"/>
                        <TextBlock Margin="0,3" TextWrapping="Wrap">
                            <Run Text="🎮  Discord server:  " Foreground="{StaticResource TextMutedBrush}"/>
                            <Hyperlink NavigateUri="https://discord.gg/RXTZhYTJz6" RequestNavigate="OpenLink"
                                       Foreground="{StaticResource TealBrush}">discord.gg/RXTZhYTJz6</Hyperlink>
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ===== Toast / status ===== -->
        <Border x:Name="Toast" Grid.Row="2" Background="{StaticResource AccentBrush}" CornerRadius="6"
                Padding="12,8" Margin="0,10,0,0" Visibility="Collapsed" HorizontalAlignment="Center">
            <TextBlock x:Name="ToastText" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
